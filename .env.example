# Firebase web app configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_web_app_id

# AdMob app IDs
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-0000000000000000~0000000000
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-0000000000000000~0000000000

# Production EAS environment only. Development and preview ignore these values.
EXPO_PUBLIC_ADMOB_ANDROID_BANNER_UNIT_ID=ca-app-pub-0000000000000000/0000000000
EXPO_PUBLIC_ADMOB_IOS_BANNER_UNIT_ID=ca-app-pub-0000000000000000/0000000000
